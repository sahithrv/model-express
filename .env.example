MODEL_EXPRESS_ORCHESTRATOR_ADDR=127.0.0.1:8080
MODEL_EXPRESS_ALLOW_LAN=false
# Required only when MODEL_EXPRESS_ALLOW_LAN=true.
# MODEL_EXPRESS_API_TOKEN=replace-with-generated-token
# Remote training orchestrator URLs/tunnels also require MODEL_EXPRESS_ALLOW_LAN=true plus MODEL_EXPRESS_API_TOKEN.
# Tunnel URLs are only for explicit remote training sessions; do not tunnel DB, MLflow, or MinIO console ports.
# MODAL_ORCHESTRATOR_URL=https://your-8080-tunnel.trycloudflare.com
# MODAL_S3_ENDPOINT_URL=https://your-scoped-storage-endpoint.example.com
# Modal refuses the local MinIO root credential pair unless MODEL_EXPRESS_ALLOW_MODAL_ROOT_STORAGE=true is set explicitly.
# Prefer managed storage with scoped credentials or presigned access for remote training.
# MODEL_EXPRESS_MODAL_AWS_ACCESS_KEY_ID=replace-with-scoped-access-key
# MODEL_EXPRESS_MODAL_AWS_SECRET_ACCESS_KEY=replace-with-scoped-secret-key
AWS_ACCESS_KEY_ID=model_express
AWS_SECRET_ACCESS_KEY=model_express_password
AWS_DEFAULT_REGION=us-east-1
MODAL_GPU_TYPE=T4
MODEL_EXPRESS_MAX_AUTO_WORKERS=4
MODEL_EXPRESS_LLM_MODEL=gpt-5.4-mini
MODEL_EXPRESS_VISUAL_LLM_MODEL=gpt-5.4-mini
MODEL_EXPRESS_LLM_API_STYLE=responses
MODEL_EXPRESS_LLM_STORED_RESPONSES=true
MODEL_EXPRESS_PLANNER_STATIC_PROMPT_VERSION=compact_v1
MODEL_EXPRESS_PLANNER_CONTEXT_VERSION=v2
MODEL_EXPRESS_MEMORY_DISTILLED_FIRST=true
MODEL_EXPRESS_MEMORY_EMBEDDING_MAX_CALLS_PER_DAY=100
MODEL_EXPRESS_MEMORY_BACKFILL_LIMIT=50
MODEL_EXPRESS_MEMORY_RETRIEVAL_QUERY_CACHE_TTL_SECONDS=3600
MODEL_EXPRESS_MEMORY_LOG_ONLY_EMBEDDINGS=false
